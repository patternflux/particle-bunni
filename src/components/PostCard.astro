---
export interface Props {
  count: number;
  post: any;
  slug: string;
}

const { count, post, slug } = Astro.props;
const backgroundImage = post.data.backgroundImage || post.data.thumbnail || post.data.image;
const foregroundImage = post.data.foregroundImage;
const description = post.data.description;
const title = post.data.title;
const isLarge = count % 3 === 0;
const bgStyle = backgroundImage ? `background-image: url(${backgroundImage});` : '';
const postClass = `post-card ${isLarge ? 'post-card-large' : ''} ${backgroundImage ? 'with-image' : 'no-image'} post`;
---

<article class={postClass} style={bgStyle}>
  <a href={`/${slug}`} class="post-card-link">
    <div class="post-card-content">
      {foregroundImage && (
        <div class="post-card-foreground-wrap">
          <img class="post-card-foreground" src={foregroundImage} alt="" loading="lazy" decoding="async" />
        </div>
      )}
      <div class="post-card-meta">
        <h2 class="post-card-title">{title}</h2>
        {description && <p class="post-card-description">{description}</p>}
      </div>
    </div>
  </a>
</article>

<style>
.post-card {
  position: relative;
  flex: 1 0 auto;
  display: flex;
  height: 35vw;
  background: linear-gradient(135deg, #1f1f1f 0%, #111 100%) center center;
  background-size: cover;
  overflow: hidden;
  counter-increment: posts;
  margin: 1rem;
  border-radius: 12px;
}

@media (max-width: 700px) {
  .post-card {
    flex: 1 1 100%;
    height: 70vw;
  }
}

.post-card-large { flex: 1 1 100%; }
.post-card-link { flex: 1 1 auto; display: block; text-decoration: none; }

.post-card-content {
  display: grid;
  grid-template-rows: minmax(0, 1fr) auto;
  align-items: end;
  position: absolute;
  inset: 0;
  color: #fff;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.84) 0%, rgba(0, 0, 0, 0.62) 34%, rgba(0, 0, 0, 0.26) 100%);
  opacity: 1;
  transition: opacity 0.5s cubic-bezier(0.33, 0, 0.2, 1);
  padding: 1.4rem;
}

.post-card-link:focus-visible {
  outline: 2px solid #fff;
  outline-offset: -2px;
}

.post-card-foreground-wrap {
  grid-row: 1;
  flex: 0 0 auto;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 40px 0;
  min-height: 0;
  overflow: hidden;
}

.post-card-foreground {
  height: 100%;
  max-height: 100%;
  max-width: 85%;
  width: auto;
  object-fit: contain;
}

.post-card-meta {
  grid-row: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.7rem;
}

.post-card-title {
  margin: 0;
  display: block;
  font-size: clamp(2.6rem, 2.2vw, 3.2rem);
  max-width: 92%;
  text-align: center;
  text-shadow: 0 1px 6px rgba(0, 0, 0, 0.85);
  font-family: var(--font-sans-serif);
  font-variant: small-caps;
  text-transform: none;
  font-weight: 500;
  line-height: 1.1;
}

.post-card-description {
  margin: 0;
  width: min(92%, 65ch);
  text-align: center;
  font-size: clamp(1.8rem, 1.15vw, 2.2rem);
  line-height: 1.3;
  color: rgba(255, 255, 255, 0.94);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-card-large .post-card-description {
  -webkit-line-clamp: 3;
}

.post-card.no-image::before {
  display: block;
  content: counter(posts);
  position: absolute;
  bottom: -0.15em;
  right: 5vw;
  font-size: 28vw;
  line-height: 1em;
  font-weight: var(--font-heavy);
  letter-spacing: -0.1em;
  color: rgba(0, 0, 0, 0.2);
}

.post-card.no-image .post-card-content {
  align-items: end;
  padding: 1.4rem;
}

.post-card.no-image .post-card-title {
  font-size: clamp(2.8rem, 2.4vw, 3.4rem);
  line-height: 1.2em;
  text-align: center;
}

.post-card.no-image:hover .post-card-title { text-decoration: underline; }

@media (max-width: 1200px) {
  .post-card.no-image .post-card-title { font-size: clamp(2.3rem, 2.2vw, 2.8rem); }
}
@media (max-width: 700px) {
  .post-card.no-image::before { font-size: 50vw; }
  .post-card-foreground-wrap {
    padding: 30px 0;
  }
  .post-card-foreground {
    max-width: 88%;
  }
  .post-card-title { font-size: clamp(2.2rem, 7.2vw, 3rem); }
  .post-card-description { font-size: clamp(1.5rem, 4.4vw, 1.8rem); }
}
</style>
