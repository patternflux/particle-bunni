<style>
  .footer-social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-bottom: 10px;
  }

  .footer-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: var(--color-base);
    border: 1px solid color-mix(in srgb, var(--color-base) 35%, transparent);
    opacity: 0.78;
    transition: opacity 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }

  .footer-social a:hover {
    opacity: 1;
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--color-base) 60%, transparent);
  }

  .footer-social a:focus-visible {
    opacity: 1;
    outline: 2px solid var(--color-base);
    outline-offset: 2px;
  }
</style>
