---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allNews = (await getCollection('news')).filter((post) => !post.data.draft);
const tags = [...new Set(allNews.flatMap((post) => post.data.tags || []))].sort((a, b) => a.localeCompare(b));

const tagCounts = tags.reduce((acc, tag) => {
  acc[tag] = allNews.filter((post) => (post.data.tags || []).includes(tag)).length;
  return acc;
}, {} as Record<string, number>);
---

<Layout title="Tags" description="All tags used in news posts">
  <article class="post-content page-template no-image">
    <div class="post-content-body">
      <h1>Tags</h1>
      <div class="tags-list">
        {tags.map((tag) => (
          <a href={`/tags/${tag}/`} class="tag-item">#{tag} ({tagCounts[tag]})</a>
        ))}
      </div>
    </div>
  </article>
</Layout>

<style>
  .tags-list { display: flex; flex-wrap: wrap; gap: 12px; }
  .tag-item {
    display: inline-block;
    border: 1px solid var(--color-border);
    padding: 6px 10px;
    border-radius: 999px;
    text-decoration: none;
    color: var(--color-base);
  }
</style>
