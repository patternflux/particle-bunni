---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const allNews = (await getCollection('news')).filter((post) => !post.data.draft);
  const uniqueTags = [...new Set(allNews.flatMap((post) => post.data.tags || []))];

  return uniqueTags.map((tag) => {
    const posts = allNews
      .filter((post) => (post.data.tags || []).includes(tag))
      .sort((a, b) => new Date(b.data.pubDate || b.data.date || 0).getTime() - new Date(a.data.pubDate || a.data.date || 0).getTime());
    return { params: { tag }, props: { posts } };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
let count = 0;
---

<Layout title={`Tag: ${tag}`} description={`News tagged ${tag}`}>
  <header class="page-head">
    <h2 class="page-head-title">#{tag}</h2>
  </header>

  <div class="post-feed">
    {posts.map((post) => {
      count++;
      return <PostCard count={count} post={post} slug={`news/${post.slug}`} />;
    })}
  </div>
</Layout>
