---
import { getCollection } from 'astro:content';
import WorkTemplate from '../../templates/Work.astro';

export async function getStaticPaths() {
  const entries = (await getCollection('news'))
    .filter((entry) => !entry.data.draft)
    .sort((a, b) => new Date(b.data.pubDate || b.data.date || 0).getTime() - new Date(a.data.pubDate || a.data.date || 0).getTime());

  return entries.map((entry, index) => {
    const newer = index === 0 ? null : entries[index - 1];
    const older = index === entries.length - 1 ? null : entries[index + 1];

    return {
      params: { slug: entry.slug },
      props: { entry, next: newer, prev: older },
    };
  });
}

const { entry, next, prev } = Astro.props;
---

<WorkTemplate entry={entry} next={next} prev={prev} baseSlug="news" />
