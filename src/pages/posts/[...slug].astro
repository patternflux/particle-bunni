---
import { getCollection } from 'astro:content';
import WorkTemplate from '../../templates/Work.astro';

export async function getStaticPaths() {
  const news = (await getCollection('news')).filter((entry) => !entry.data.draft);
  const releases = (await getCollection('releases')).filter((entry) => !entry.data.draft);
  const seenSlugs = new Set<string>();

  const newsPaths = news.map((entry) => {
    seenSlugs.add(entry.slug);
    return { params: { slug: entry.slug }, props: { entry, baseSlug: 'news' } };
  });

  // Keep legacy /posts/[slug] deterministic: news wins on slug conflicts.
  const releasePaths = releases
    .filter((entry) => !seenSlugs.has(entry.slug))
    .map((entry) => ({ params: { slug: entry.slug }, props: { entry, baseSlug: 'releases' } }));

  return [...newsPaths, ...releasePaths];
}

const { entry, baseSlug } = Astro.props;
---

<WorkTemplate entry={entry} baseSlug={baseSlug} />
